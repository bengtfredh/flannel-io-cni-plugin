{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "platformAutomerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/flannel-io-cni-plugin\\.spec$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)[\\s\\S]*?%define version (?<currentValue>\\S+)"
      ],
      "extractVersionTemplate": "^v(?<version>.+)$"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["flannel-io/cni-plugin"],
      "postUpgradeTasks": {
        "commands": [
          "sed -i 's/releasebuild [0-9]*/releasebuild 1/' flannel-io-cni-plugin.spec"
        ],
        "executionMode": "branch"
      }
    }
  ]
}
