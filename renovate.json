{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "platformAutomerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/flannel-io-cni-plugin\\.spec$/"
      ],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=flannel-io/cni-plugin\\n%define version (?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "flannel-io/cni-plugin",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "flannel-io/cni-plugin"
      ],
      "postUpgradeTasks": {
        "commands": [
          "sed -i 's/releasebuild [0-9]*/releasebuild 1/' flannel-io-cni-plugin.spec"
        ],
        "executionMode": "branch"
      }
    }
  ]
}
